generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
}

enum ApplicationStatus {
  SAVED
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  TECHNICAL_ASSESSMENT
  FINAL_ROUND
  OFFER
  REJECTED
  WITHDRAWN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  WAITING_ON_INTERNAL_TEAM
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  EMAIL
  IN_APP
  PUSH
}

// ─────────────────────────────────────────────────────────────────────────────
// USER & ACCESS CONTROL
// ─────────────────────────────────────────────────────────────────────────────

/// Core user record. clerkId links this row to Clerk's user object.
model User {
  id          String        @id @default(uuid())
  supabaseId  String?       @unique
  email       String        @unique
  fullName    String
  avatarUrl   String?
  country     String?
  status      AccountStatus @default(ACTIVE)
  lastLoginAt DateTime?
  tenantId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  roles           UserRole[]
  subscriptions   Subscription[]
  auditLogs       AuditLog[]
  resumes         Resume[]
  aiUsage         AIUsage[]
  coverLetters    CoverLetter[]
  jobApplications JobApplication[]
  savedJobs       SavedJob[]
  supportTickets  SupportTicket[]
  notifications   Notification[]
  aiCredits       AICredits?

  @@index([supabaseId])
  @@index([email])
  @@index([status])
  @@index([tenantId])
  @@index([createdAt])
}

/// Named role. e.g. CANDIDATE, SUPER_ADMIN, OPERATIONS_ADMIN, SUPPORT_ADMIN, FINANCE_ADMIN
model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  users       UserRole[]

  createdAt DateTime @default(now())
}

/// Fine-grained permission. e.g. "users:read", "billing:write", "ai:bypass_limits"
model Permission {
  id          String           @id @default(uuid())
  action      String           @unique
  description String?
  roles       RolePermission[]

  createdAt DateTime @default(now())
}

/// Junction — role ↔ permission (many-to-many)
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

/// Junction — user ↔ role (many-to-many)
model UserRole {
  userId    String
  roleId    String
  grantedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING & SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────────

/// Billing plan. e.g. FREE, PREMIUM (£15/mo), PRO (£29/mo), ENTERPRISE
model Plan {
  id            String  @id @default(uuid())
  name          String  @unique
  stripePriceId String  @unique
  priceMonthly  Float
  priceYearly   Float
  currency      String  @default("GBP")
  isActive      Boolean @default(true)

  features      PlanFeature[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Key-value feature flags per plan. e.g. { featureKey: "resume_versions", value: "5" }
model PlanFeature {
  id         String @id @default(uuid())
  planId     String
  featureKey String
  value      String

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

/// Active subscription linking a user to a plan via Stripe
model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String             @unique
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  cancellationReason   String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]
  invoices Invoice[]

  @@index([userId])
  @@index([status])
}

/// Payment intent record — one per successful invoice payment
model Payment {
  id             String   @id @default(uuid())
  subscriptionId String
  stripeIntentId String   @unique
  amount         Float
  currency       String   @default("GBP")
  status         String   @default("succeeded")
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([createdAt])
}

/// Stripe invoice record for receipt tracking
model Invoice {
  id              String   @id @default(uuid())
  subscriptionId  String
  stripeInvoiceId String   @unique
  invoiceUrl      String
  pdfUrl          String
  amountPaid      Float    @default(0)
  currency        String   @default("GBP")
  createdAt       DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT  (Sprint 6)
// ─────────────────────────────────────────────────────────────────────────────

/// Immutable audit trail for all admin and system actions
model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  ipAddress    String   @default("unknown")
  action       String
  targetEntity String
  targetId     String?
  beforeState  Json?
  afterState   Json?
  metadata     Json?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPPORT TICKETS  (Sprint 6)
// ─────────────────────────────────────────────────────────────────────────────

/// User-submitted support ticket
model SupportTicket {
  id          String         @id @default(uuid())
  userId      String
  subject     String
  description String         @db.Text
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses TicketResponse[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

/// Admin or user reply within a support ticket thread
model TicketResponse {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  content   String   @db.Text
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS  (Sprint 6)
// ─────────────────────────────────────────────────────────────────────────────

/// Email or in-app notification sent to a user
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType @default(EMAIL)
  subject   String
  content   String           @db.Text
  isRead    Boolean          @default(false)
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI CREDITS  (Sprint 6 — admin can grant credits)
// ─────────────────────────────────────────────────────────────────────────────

/// Optional per-user AI credit balance (admin-granted)
model AICredits {
  id           String    @id @default(uuid())
  userId       String    @unique
  totalCredits Int       @default(0)
  usedCredits  Int       @default(0)
  grantedBy    String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// RESUMES  (Sprint 2)
// ─────────────────────────────────────────────────────────────────────────────

/// A candidate's uploaded resume document stored on AWS S3
model Resume {
  id           String  @id @default(uuid())
  userId       String
  title        String
  originalName String
  s3Key        String
  s3Url        String
  fileSize     Int     @default(0)
  mimeType     String  @default("application/pdf")
  parsedText   String? @db.Text
  atsScore     Int     @default(0)
  isDefault    Boolean @default(false)

  /// Full JSON analysis result from GPT-4o ATS analyser
  analysisResult Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions     ResumeVersion[]
  aiUsage      AIUsage[]
  coverLetters CoverLetter[]

  @@index([userId])
  @@index([userId, isDefault])
}

/// Point-in-time snapshot of a resume after AI tailoring (Sprint 3)
model ResumeVersion {
  id              String   @id @default(uuid())
  resumeId        String
  versionNum      Int
  tailoredContent String?  @db.Text
  changesApplied  Json?
  keywordDensity  Json?
  scoreBefore     Int      @default(0)
  scoreAfter      Int      @default(0)
  s3Key           String?
  s3Url           String?
  jobTitle        String?
  companyName     String?
  createdAt       DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, versionNum])
  @@index([resumeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI USAGE  (Sprint 2)
// ─────────────────────────────────────────────────────────────────────────────

/// Records every call made to an AI provider for cost tracking and auditing
model AIUsage {
  id               String   @id @default(uuid())
  userId           String
  resumeId         String?
  modelName        String
  feature          String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCostUsd Float
  tier             String?  @default("free")
  createdAt        DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
  @@index([modelName])
}

// ─────────────────────────────────────────────────────────────────────────────
// COVER LETTERS  (Sprint 3)
// ─────────────────────────────────────────────────────────────────────────────

enum CoverLetterVariant {
  STANDARD
  CONCISE
  DETAILED
  HIRING_MANAGER
}

/// AI-generated cover letter saved by the user
model CoverLetter {
  id                String             @id @default(uuid())
  userId            String
  resumeId          String?
  jobTitle          String
  companyName       String
  hiringManagerName String?
  variant           CoverLetterVariant @default(STANDARD)
  content           String             @db.Text
  wordCount         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, companyName])
}

// ─────────────────────────────────────────────────────────────────────────────
// JOB TRACKER  (Sprint 4)
// ─────────────────────────────────────────────────────────────────────────────

/// Lightweight company record — auto-created or manually added
model Company {
  id       String  @id @default(uuid())
  name     String  @unique
  website  String?
  logoUrl  String?
  industry String?

  applications JobApplication[]
  savedJobs    SavedJob[]

  createdAt DateTime @default(now())
}

/// One row per job application tracked by a candidate
model JobApplication {
  id             String            @id @default(uuid())
  userId         String
  companyId      String?
  jobTitle       String
  companyName    String
  location       String?
  jobUrl         String?
  jobDescription String?           @db.Text
  salary         String?
  status         ApplicationStatus @default(SAVED)
  appliedDate    DateTime?
  followUpDate   DateTime?
  notes          String?           @db.Text
  resumeId       String?
  coverLetterId  String?
  source         String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([updatedAt])
}

/// Jobs bookmarked for future application (not yet applied)
model SavedJob {
  id          String    @id @default(uuid())
  userId      String
  companyId   String?
  jobTitle    String
  companyName String
  location    String?
  jobUrl      String?   @unique
  salary      String?
  postedAt    DateTime?
  savedAt     DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
}
