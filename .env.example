# ==================================================
# JOBIN ENVIRONMENT VARIABLES - COPY TO .env
# ==================================================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres:your-supabase-db-password@db.your-supabase-project.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:your-supabase-db-password@db.your-supabase-project.supabase.co:5432/postgres"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-db-password
POSTGRES_DB=postgres

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Backend (NestJS) ---
PORT=4000
NODE_ENV=development

# --- Supabase (Authentication & DB Link) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Cloudflare R2 (S3-compatible Document Storage) ---
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=jobin-resumes

# --- Google Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_PAID_TIER=false

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@jobin.ai
RESEND_FROM_NAME=JobIN

# --- Sentry & PostHog ---
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- Frontend (Next.js) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
