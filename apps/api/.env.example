# ==================================================
# JOBIN API — Environment Variables
# Copy this file to .env and fill in real values
# ==================================================

# ── Application ─────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL) ────────────────────────
DATABASE_URL="postgresql://postgres:your-supabase-db-password@db.your-supabase-project.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:your-supabase-db-password@db.your-supabase-project.supabase.co:5432/postgres"

# ── Redis ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Supabase Authentication ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── CORS ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Cloudflare R2 (S3-compatible storage) ────────
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=jobin-resumes

# ── Stripe (Payments) ────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Gemini AI ─────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_PAID_TIER=false

# ── Email — Resend ────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@jobin.ai
RESEND_FROM_NAME=JobIN

# ── App URL (used in email links) ─────────────────
NEXT_PUBLIC_URL=http://localhost:3000

# ── Sentry ────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn
