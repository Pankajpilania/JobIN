{
  "extends": [
    "next/core-web-vitals"
  ],
  "rules": {
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-undef": "off",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-console": "off",
    "react/react-in-jsx-scope": "off",
    "@typescript-eslint/no-explicit-any": "off",
    "no-restricted-syntax": [
      "error",
      {
        "selector": "Property[key.name=/^(leadingRelaxed|leadingNone|leadingTight|leadingSnug|leadingNormal|leadingLoose|trackingTight|trackingWide|trackingWidest|justifyText|fontMedium|fontBold|fontSemibold|textSm|textBase|textLg|textXl|roundedFull|roundedLg|truncate)$/]",
        "message": "Do not use Tailwind class names as inline style properties. Use valid CSS property names instead."
      }
    ]
  },
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "ignorePatterns": ["node_modules", "dist", ".next", "coverage"]
}
